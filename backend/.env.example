# Quiniela Predictor Pro — Variables de entorno
# IMPORTANTE: Nunca incluir este archivo en git (ya está en .gitignore)

# ── Base de datos ──────────────────────────────────────────────────────────
# Para desarrollo local usa SQLite:
DATABASE_URL=sqlite:///./quiniela.db
# Para producción en Railway (descomenta y usa la URL de tu Postgres):
# DATABASE_URL=postgresql://user:password@host:5432/quiniela_db

# ── API Keys externas ──────────────────────────────────────────────────────
SPORTMONKS_API_KEY=your_sportmonks_key_here
GOALSERVE_API_KEY=your_goalserve_key_here

# ── JWT / Seguridad (opcional para futura autenticación) ──────────────────
SECRET_KEY=change_this_to_a_random_32_char_string

# ── CORS ──────────────────────────────────────────────────────────────────
# URL del frontend en producción (Vercel)
FRONTEND_URL=https://quiniela-pro.vercel.app
